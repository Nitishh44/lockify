
<%- include('include/_header')%> <!-- Common header yahan include kiya gaya hai -->

<!--Main Site-->
<main id="site-main">
    <div class="container">
        <div class="box-nav d-flex justify-between">
            <a href="/add-entry" class="border-shadow">
                <span class="text-gradient">New Entry <i class="fa-solid fa-key"></i></span>
                <!-- New password add karne ke liye button -->
            </a>
        </div>

        <!--form handling-->
            <form action="/" method="POST">
                <input type="text" id="searchInput" placeholder="Search passwords..."/>
                <!-- Entries table ko wrap karne ke liye form -->
                <table class="table">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Purpose</th>
                            <th>Email</th>
                            <th>Username</th>
                            <th>Password</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                        <!-- Password entries ke table headers -->
                    </thead>
                    <tbody>
                        <%- include('include/_show')%> <!-- Database se aayi entries yahan show hoti hain -->
                    </tbody>
                </table>
            </form>
        <!--/form handling-->
    </div>
</main>
<!--Main Site-->


<!--include footer-->
    <%- include('include/_footer')%>
<!--/include footer-->